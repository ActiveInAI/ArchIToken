[Unit]
Description=ArchIToken ArClaw local model sync
After=network-online.target

[Service]
Type=simple
WorkingDirectory=/home/insome/dev/insomeos
ExecStart=/home/insome/.bun/bin/bun /home/insome/dev/insomeos/tools/arclaw_model_sync.mjs --watch --interval 60
Restart=always
RestartSec=5

[Install]
WantedBy=default.target
