# ArchIToken · K8s manifests · 环境变量示例
# 复制为 .env 后填入真实值 · .env 被 .gitignore 屏蔽
#
# Postgres baseline (2026-04-22+)
POSTGRES_USER=architoken
POSTGRES_PASSWORD=CHANGE_ME_USE_STRONG_RANDOM
POSTGRES_DB=architoken

# Rainbond 镜像仓库(goodrain.me)凭证
# 不要用默认 admin/admin1234
RAINBOND_USERNAME=admin
RAINBOND_PASSWORD=CHANGE_ME_USE_STRONG_RANDOM
RAINBOND_REGISTRY=goodrain.me
