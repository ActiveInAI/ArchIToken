#!/usr/bin/env bash
# panaec-dxf-to-ifc <input.dxf> <output.ifc> [--name NAME]
set -euo pipefail
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
WORKER_DIR="$(cd "${SCRIPT_DIR}/.." && pwd)"
PYTHON_BIN="${ARCHITOKEN_WORKER_PYTHON:-${WORKER_DIR}/.venv/bin/python}"
[[ -x "${PYTHON_BIN}" ]] || PYTHON_BIN="${PYTHON:-python3}"
exec "${PYTHON_BIN}" "${SCRIPT_DIR}/architoken_dxf_to_ifc.py" "$@"
