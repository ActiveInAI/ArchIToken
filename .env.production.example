# ArchIToken production runtime environment
# Copy to your secret manager or local .env.production; do not commit real secrets.

ARCHITOKEN_PROFILE=production
ARCHITOKEN_SERVER__HOST=0.0.0.0
ARCHITOKEN_SERVER__PORT=8080

# Database: use PgBouncer in front of PostgreSQL/Supabase for production.
DATABASE_URL=postgres://architoken:REPLACE@pgbouncer:6432/architoken
ARCHITOKEN_DATABASE__URL=postgres://architoken:REPLACE@pgbouncer:6432/architoken

# Cache / queue / workflow.
ARCHITOKEN_CACHE__URL=redis://valkey:6379/0
NATS_URL=nats://nats:4222
TEMPORAL_ADDRESS=temporal:7233

# S3-compatible object store. S3_PUBLIC_ENDPOINT is the URL returned to clients.
S3_ENDPOINT=http://seaweed-s3:8333
S3_PUBLIC_ENDPOINT=https://assets.example.com
S3_ACCESS_KEY=REPLACE
S3_SECRET_KEY=REPLACE
S3_BUCKET=architoken-assets

# Observability.
ARCHITOKEN_OBSERVABILITY__OTLP_ENDPOINT=http://otel-collector:4317
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
ARCHITOKEN_OBSERVABILITY__SERVICE_NAME=architoken-gateway

# Production readiness gates.
ARCHITOKEN_PHASE8_PGBOUNCER_REQUIRED=true
ARCHITOKEN_PHASE8_OBJECT_STORE_REQUIRED=true
ARCHITOKEN_PHASE8_OTEL_REQUIRED=true
ARCHITOKEN_PHASE8_MAX_REQUEST_BODY_BYTES=16777216
ARCHITOKEN_PHASE8_MAX_UPLOAD_BYTES=5368709120
ARCHITOKEN_PHASE8_API_RPS_LIMIT=10000
ARCHITOKEN_PHASE8_TENANT_RPS_LIMIT=1000
ARCHITOKEN_PHASE8_ACTOR_RPS_LIMIT=100
ARCHITOKEN_PHASE8_MAX_CONCURRENT_UPLOADS_PER_TENANT=32
ARCHITOKEN_PHASE8_MAX_CONCURRENT_CONVERSION_JOBS_PER_TENANT=16
ARCHITOKEN_PHASE8_DB_POOL_MAX_CONNECTIONS=64

# Auth and model providers.
ARCHITOKEN_AUTH__JWT_SECRET=REPLACE_WITH_32_BYTES_RANDOM_SECRET
ARCHITOKEN_AUTH__JWT_ISSUER=https://auth.architoken.example.com
ARCHITOKEN_FRONTEND_BASE_URL=https://ko.tw.cn
# Keep OAuth callback same-origin with the frontend API proxy so auth cookies are set on the frontend domain.
ARCHITOKEN_PUBLIC_API_BASE_URL=https://ko.tw.cn/api/architoken
ARCHITOKEN_OAUTH_WECHAT_CLIENT_ID=REPLACE_WITH_WECHAT_OPEN_PLATFORM_APPID
ARCHITOKEN_OAUTH_WECHAT_CLIENT_SECRET=REPLACE_WITH_WECHAT_OPEN_PLATFORM_SECRET
ARCHITOKEN_INFERENCE__DEFAULT_ENGINE=hugging_face
ARCHITOKEN_INFERENCE__WHITELISTED_MODELS=architoken-planner,architoken-generator,architoken-evaluator,nvidia/Nemotron-3-Nano-Omni-30B-A3B-Reasoning-NVFP4,Multilingual-Multimodal-NLP/IndustrialCoder-Thinking-32B-FP8,PaddlePaddle/PaddleOCR-VL-1.5,baidu/ERNIE-Image,black-forest-labs/FLUX.2-dev-NVFP4,Lightricks/LTX-2.3-nvfp4,tencent/HY-World-2.0,nvidia/asset-harvester,nvidia/Lyra-2.0
ARCHITOKEN_GENERATION__PROVIDER=http_multimodal
ARCHITOKEN_GENERATION__TEXT_TO_BIM_URL=https://generation.example.com/v1/generate/text-to-bim
ARCHITOKEN_GENERATION__TEXT_TO_IMAGE_URL=https://generation.example.com/v1/generate/text-to-image
ARCHITOKEN_GENERATION__IMAGE_TO_VIDEO_URL=https://generation.example.com/v1/generate/image-to-video

# Hugging Face provider boundary. Keep tokens server-side.
HF_TOKEN=REPLACE_WITH_HF_TOKEN
HUGGINGFACE_API_TOKEN=
ARCHITOKEN_HF_MODEL_REPOSITORY_DIR=/var/lib/architoken/models/huggingface
ARCHITOKEN_HF_MODEL_ROUTES={"chat":"nvidia/Nemotron-3-Nano-Omni-30B-A3B-Reasoning-NVFP4","code":"Multilingual-Multimodal-NLP/IndustrialCoder-Thinking-32B-FP8","ocr":"PaddlePaddle/PaddleOCR-VL-1.5","text_to_image":"baidu/ERNIE-Image","image_to_image":"black-forest-labs/FLUX.2-dev-NVFP4","image_to_video":"Lightricks/LTX-2.3-nvfp4","image_to_3d":"tencent/HY-World-2.0","object_to_3d_asset":"nvidia/asset-harvester","world_3d_research":"nvidia/Lyra-2.0"}
ARCHITOKEN_HF_LOCAL_CHAT_URL=http://hf-chat:8000/v1/chat/completions
ARCHITOKEN_HF_CHAT_URL=
ARCHITOKEN_TEXT_TO_IMAGE_PROVIDER=huggingface
ARCHITOKEN_IMAGE_TO_VIDEO_PROVIDER=huggingface
ARCHITOKEN_HF_LOCAL_TEXT_TO_IMAGE_URL=http://hf-image:7860/v1/generate/text-to-image
ARCHITOKEN_HF_LOCAL_IMAGE_TO_VIDEO_URL=http://hf-video:7861/v1/generate/image-to-video
ARCHITOKEN_HF_REMOTE_ENABLED=0

# File adapter services. Empty values are not production-ready for that family.
PAPERCLIP_DASHBOARD_URL=http://paperclip:3111
NEXT_PUBLIC_PAPERCLIP_PUBLIC_URL=https://paperclip.architoken.example.com
PAPERCLIP_INSTANCE_ID=architoken-production-manufacturing
PAPERCLIP_CONFIG=/paperclip/instances/architoken-production-manufacturing/config.json
PAPERCLIP_PUBLIC_URL=https://paperclip.architoken.example.com
PAPERCLIP_AUTH_PUBLIC_BASE_URL=https://paperclip.architoken.example.com
PAPERCLIP_ALLOWED_HOSTNAMES=paperclip.architoken.example.com,architoken.example.com
BETTER_AUTH_BASE_URL=https://paperclip.architoken.example.com
BETTER_AUTH_URL=https://paperclip.architoken.example.com
BETTER_AUTH_TRUSTED_ORIGINS=https://paperclip.architoken.example.com,https://architoken.example.com
PAPERCLIP_DEPLOYMENT_MODE=authenticated
PAPERCLIP_DEPLOYMENT_EXPOSURE=private
PAPERCLIP_BETTER_AUTH_SECRET=REPLACE_WITH_32_BYTES_RANDOM_SECRET
PAPERCLIP_AGENT_JWT_SECRET=REPLACE_WITH_32_BYTES_RANDOM_SECRET
LIBREOFFICE_ADAPTER_URL=https://office-adapter.example.com
ARCHITOKEN_PUBLIC_BASE_URL=https://architoken.example.com
ARCHITOKEN_OFFICE_EDITOR_PROVIDER=collabora
COLLABORA_ONLINE_URL=https://collabora.example.com
COLLABORA_WOPI_TOKEN_SECRET=REPLACE_WITH_32_BYTES_RANDOM_SECRET
COLLABORA_ACCESS_TOKEN_TTL_SECONDS=86400
COLLABORA_ONLINE_IMAGE_TAG=REPLACE_WITH_PINNED_RELEASE
COLLABORA_ALLOWED_HOST_REGEX=architoken\\.example\\.com
ONLYOFFICE_DOCUMENT_SERVER_URL=
ONLYOFFICE_JWT_SECRET=
ONLYOFFICE_DOCUMENT_SERVER_IMAGE_TAG=
ARCHITOKEN_OFFICE_EDIT_MAX_BYTES=536870912
ARCHITOKEN_CODE_EDITOR_PROVIDER=monaco
CODE_SERVER_URL=https://code.architoken.example.com
CODE_SERVER_WORKSPACE_MOUNT=/home/coder/project
ARCHITOKEN_CODE_SERVER_WORKSPACE_DIR=/var/lib/architoken/code-workspaces
CODE_SERVER_IMAGE_TAG=4.121.0
CODE_SERVER_PASSWORD=REPLACE_WITH_32_BYTES_RANDOM_SECRET
UNIVER_DOCUMENT_SERVICE_URL=https://univer.example.com
MARKITDOWN_WORKER_URL=http://markitdown-worker:8080
STIRLING_PDF_URL=http://stirling-pdf:8080
STIRLING_PDF_API_KEY=REPLACE_IF_ENABLED
STIRLING_PDF_TOKEN=REPLACE_IF_ENABLED
STIRLING_PDF_IMAGE_TAG=2.11.0
STIRLING_PDF_ENABLE_SECURITY=true
STIRLING_PDF_ENABLE_LOGIN=true
PADDLEOCR_WORKER_URL=http://paddleocr-worker:8080
PADDLE_PDX_MODEL_SOURCE=bos
PADDLE_PDX_DISABLE_MODEL_SOURCE_CHECK=true
MINERU_BINARY=mineru
ARCHITOKEN_AI_PROVIDER_ROUTER_URL=http://ai-provider-router:8080
POSTGIS_DSN=host=postgis port=5432 dbname=architoken user=architoken password=REPLACE
OPEN_DESIGN_URL=http://open-design:8080
SIYUAN_API_URL=http://siyuan:6806
SIYUAN_TOKEN=REPLACE_IF_ENABLED
IFCOPENSHELL_WORKER_URL=http://ifcopenshell-worker:8080
IFCCONVERT_BINARY=IfcConvert
BUILDINGSMART_VALIDATE_URL=http://buildingsmart-validate:8080
BUILDINGSMART_VALIDATE_OPERATION_PATH=/api/validate
BUILDINGSMART_VALIDATE_TOKEN=REPLACE_IF_ENABLED
IFCDB_AGENT_URL=http://ifcdb-agent:8080
IFCDB_AGENT_VERSION=v1.0.9
IFCDB_AGENT_HEALTH_PATH=/health
IFCDB_AGENT_INDEX_PATH=/api/v1/ifcdb/index
IFCDB_AGENT_QUERY_PATH=/api/v1/ifcdb/query
IFCDB_AGENT_EXPORT_PATH=/api/v1/ifcdb/export
IFCDB_AGENT_CLASH_PATH=/api/v1/ifcdb/clash
IFCDB_AGENT_QUANTITY_PATH=/api/v1/ifcdb/quantity
OCCT_WORKER_URL=http://occt-worker:8080
CADQUERY_WORKER_URL=http://cadquery-worker:8080
FREECAD_WORKER_URL=http://freecad-worker:8080
CGAL_WORKER_URL=http://cgal-worker:8080
PDAL_WORKER_URL=http://pdal-worker:8080
GDAL_WORKER_URL=http://gdal-worker:8080
FFMPEG_WORKER_URL=http://ffmpeg-worker:8080
ANTV_DIAGRAM_WORKER_URL=http://diagram-worker:8080
BLENDER_WORKER_URL=http://blender-worker:8080
BLENDER_BINARY=blender
BSDD_API_URL=https://api.bsdd.buildingsmart.org
SPECKLE_SERVER_URL=https://speckle.example.com
SPECKLE_TOKEN=REPLACE
CESIUM_ION_TOKEN=REPLACE
FORGECAD_NPM_VERSION=REPLACE_WITH_PINNED_RELEASE
FORGECAD_URL=
FORGECAD_TOKEN=REPLACE
ARCHITOKEN_WORKER_SUBJECT=architoken.conversion.jobs
ARCHITOKEN_WORKER_RESULT_SUBJECT=architoken.conversion.results
ARCHITOKEN_GATEWAY_URL=http://gateway:8080
ARCHITOKEN_WORKER_RESULT_TOKEN=REPLACE_WITH_32_BYTES_RANDOM_SECRET

# Licensed/vendor adapter gates. Set only when official credentials/runtime exist.
AUTODESK_APS_CLIENT_ID=REPLACE
AUTODESK_APS_CLIENT_SECRET=REPLACE
AUTODESK_APS_REGION=US
DWG_ADAPTER_URL=https://dwg-adapter.example.com
REVIT_ADAPTER_URL=https://revit-adapter.example.com
NAVISWORKS_ADAPTER_URL=https://navisworks-adapter.example.com
TEKLA_ADAPTER_URL=https://tekla-adapter.example.com
RHINO_ADAPTER_URL=https://rhino-adapter.example.com
GRASSHOPPER_ADAPTER_URL=https://grasshopper-adapter.example.com
SKETCHUP_ADAPTER_URL=https://sketchup-adapter.example.com
# SKP conversion must be backed by a legal SketchUp reader/exporter command or
# licensed service. SKP->IFC must produce real IFC; GLB is only a final viewing
# fallback and must not be reported as OpenBIM exchange success.
PRENGINE_SKP_TO_IFC_COMMAND=
PRENGINE_SKP_TO_IFC_ARGS=["{source}","{output}"]
PRENGINE_SKP_CONVERTER_COMMAND=
PRENGINE_SKP_CONVERTER_ARGS=["{source}","{output}"]
SKP2GLB_BIN=
SKP_TO_GLB_BIN=
SOLIDWORKS_ADAPTER_URL=https://solidworks-adapter.example.com
CATIA_ADAPTER_URL=https://catia-adapter.example.com
BENTLEY_ADAPTER_URL=https://bentley-adapter.example.com
