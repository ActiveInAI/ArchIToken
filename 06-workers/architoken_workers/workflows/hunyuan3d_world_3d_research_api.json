{
  "1": {
    "class_type": "ImageOnlyCheckpointLoader",
    "inputs": {
      "ckpt_name": "hunyuan3d-dit-v2_fp16.safetensors"
    }
  },
  "2": {
    "class_type": "LoadImage",
    "inputs": {
      "image": "{{input_image}}"
    }
  },
  "3": {
    "class_type": "CLIPVisionEncode",
    "inputs": {
      "clip_vision": ["1", 1],
      "image": ["2", 0],
      "crop": "none"
    }
  },
  "4": {
    "class_type": "Hunyuan3Dv2Conditioning",
    "inputs": {
      "clip_vision_output": ["3", 0]
    }
  },
  "5": {
    "class_type": "EmptyLatentHunyuan3Dv2",
    "inputs": {
      "resolution": 4096,
      "batch_size": 1
    }
  },
  "6": {
    "class_type": "KSampler",
    "inputs": {
      "model": ["1", 0],
      "seed": "{{seed}}",
      "steps": 50,
      "cfg": 5.0,
      "sampler_name": "euler",
      "scheduler": "normal",
      "positive": ["4", 0],
      "negative": ["4", 1],
      "latent_image": ["5", 0],
      "denoise": 1.0
    }
  },
  "7": {
    "class_type": "VAEDecodeHunyuan3D",
    "inputs": {
      "samples": ["6", 0],
      "vae": ["1", 2],
      "num_chunks": 16000,
      "octree_resolution": 384
    }
  },
  "8": {
    "class_type": "VoxelToMesh",
    "inputs": {
      "voxel": ["7", 0],
      "algorithm": "surface net",
      "threshold": 0.6
    }
  },
  "9": {
    "class_type": "SaveGLB",
    "inputs": {
      "mesh": ["8", 0],
      "filename_prefix": "{{filename_prefix}}"
    }
  }
}
