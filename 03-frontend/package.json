{
  "name": "@insomeos/frontend",
  "version": "2.0.0",
  "private": true,
  "description": "InsomeOS Web Frontend · Next.js 16 RSC · Single-Path React",
  "license": "Apache-2.0",
  "author": "ActiveInAI <ActiveInAI@outlook.com>",
  "repository": {
    "type": "git",
    "url": "https://github.com/ActiveInAI/insomeos.git",
    "directory": "03-frontend"
  },
  "engines": {
    "node": "25.9.0",
    "bun": "1.3.12"
  },
  "packageManager": "bun@1.3.12",
  "scripts": {
    "dev": "next dev --turbopack --port 3000",
    "build": "next build --turbopack",
    "start": "next start --port 3000",
    "lint": "next lint && eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "storybook": "storybook dev -p 6006",
    "storybook:build": "storybook build",
    "sdk:generate": "openapi-generator-cli generate -i ../04-backend/openapi.yaml -g typescript-fetch -o ./lib/sdk",
    "license-check": "license-checker --failOn 'GPL;AGPL;LGPL;SSPL;BUSL' --production"
  },
  "dependencies": {
    "next": "16.2.4",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "react-native-web": "0.19.13",
    "@tanstack/react-query": "5.99.1",
    "@tanstack/react-query-devtools": "5.99.1",
    "zustand": "5.0.12",
    "d3": "7.9.0",
    "three": "0.184.0",
    "@react-three/fiber": "9.1.2",
    "@react-three/drei": "10.3.0",
    "@ai-sdk/amazon-bedrock": "3.0.97",
    "ai": "5.0.20",
    "@supabase/supabase-js": "2.103.3",
    "@supabase/ssr": "0.7.8",
    "immer": "10.1.3",
    "zod": "4.2.1",
    "react-hook-form": "7.64.1",
    "@hookform/resolvers": "5.4.0",
    "lucide-react": "0.514.0",
    "class-variance-authority": "0.8.0",
    "tailwind-merge": "3.6.1",
    "clsx": "2.2.0",
    "sonner": "2.2.4",
    "cmdk": "1.1.4",
    "@radix-ui/react-dialog": "1.1.19",
    "@radix-ui/react-dropdown-menu": "2.1.19",
    "@radix-ui/react-popover": "1.1.19",
    "@radix-ui/react-select": "2.2.19",
    "@radix-ui/react-slot": "1.2.9",
    "@radix-ui/react-tabs": "1.1.19",
    "@radix-ui/react-toast": "1.3.4",
    "@radix-ui/react-tooltip": "1.3.4",
    "date-fns": "4.3.0",
    "next-intl": "4.8.0"
  },
  "devDependencies": {
    "typescript": "6.0.3",
    "@types/react": "19.2.5",
    "@types/react-dom": "19.2.5",
    "@types/node": "25.9.0",
    "@types/d3": "7.9.4",
    "@types/three": "0.184.0",
    "tailwindcss": "4.2.2",
    "@tailwindcss/postcss": "4.2.2",
    "postcss": "8.6.3",
    "autoprefixer": "10.5.4",
    "eslint": "9.36.0",
    "eslint-config-next": "16.2.4",
    "eslint-plugin-boundaries": "5.1.0",
    "@typescript-eslint/eslint-plugin": "8.48.0",
    "@typescript-eslint/parser": "8.48.0",
    "vitest": "3.6.1",
    "@vitejs/plugin-react": "5.4.2",
    "@testing-library/react": "17.1.1",
    "@testing-library/jest-dom": "6.7.2",
    "@testing-library/user-event": "15.3.1",
    "jsdom": "27.4.1",
    "playwright": "1.56.4",
    "@playwright/test": "1.56.4",
    "@storybook/react": "10.3.8",
    "@storybook/nextjs": "10.3.8",
    "storybook": "10.3.8",
    "license-checker": "25.0.2",
    "prettier": "4.0.3",
    "prettier-plugin-tailwindcss": "0.8.1",
    "husky": "9.3.7",
    "lint-staged": "16.3.4",
    "@openapitools/openapi-generator-cli": "2.23.0"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  }
}
