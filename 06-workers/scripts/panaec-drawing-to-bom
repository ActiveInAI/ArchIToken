#!/usr/bin/env bash
# panaec-drawing-to-bom <input.dxf|.dwg> <output.json> [--csv-dir DIR] [--name NAME]
# DWG 先经 LibreDWG dwg2dxf 真实转换,再走 ezdxf 块引用统计。
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
WORKER_DIR="$(cd "${SCRIPT_DIR}/.." && pwd)"
PYTHON_BIN="${ARCHITOKEN_WORKER_PYTHON:-${WORKER_DIR}/.venv/bin/python}"
LIBREDWG_DIR="${LIBREDWG_BIN_DIR:-/home/insome/libredwg/bin}"

input="${1:?usage: panaec-drawing-to-bom <input.dxf|.dwg> <output.json> ...}"
shift

case "${input,,}" in
  *.dwg)
    work="$(mktemp -d /tmp/drawing-bom-XXXXXX)"
    trap 'rm -rf "$work"' EXIT
    "$LIBREDWG_DIR/dwg2dxf" -o "$work/converted.dxf" "$input" 1>&2
    [ -s "$work/converted.dxf" ]
    exec "$PYTHON_BIN" "${SCRIPT_DIR}/architoken_dxf_to_bom.py" "$work/converted.dxf" "$@"
    ;;
  *)
    exec "$PYTHON_BIN" "${SCRIPT_DIR}/architoken_dxf_to_bom.py" "$input" "$@"
    ;;
esac
