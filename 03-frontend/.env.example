# ArchIToken 前端环境变量模板
# 复制为 .env(或 .env.local)后按需填写;全部留空也能启动,只是对应集成不可用。

# 前端访问后端 API 的基础地址(会内联进浏览器代码,勿填密钥)
NEXT_PUBLIC_ARCHITOKEN_API_BASE_URL=

# OpenClaw 网关(AI 能力接入;不用 AI 功能可留空)
OPENCLAW_DASHBOARD_URL=
OPENCLAW_GATEWAY_HTTP_URL=
OPENCLAW_GATEWAY_WS_URL=
OPENCLAW_GATEWAY_TOKEN=
OPENCLAW_DEFAULT_MODEL=
OPENCLAW_FORCE_DEFAULT_MODEL=0

# 对外公开的站点基础地址(生成回调/链接用)
ARCHITOKEN_PUBLIC_BASE_URL=

# 在线 Office 编辑(collabora 或 onlyoffice;不用在线编辑可整段留空)
ARCHITOKEN_OFFICE_EDITOR_PROVIDER=
COLLABORA_ONLINE_URL=
COLLABORA_WOPI_TOKEN_SECRET=
COLLABORA_ACCESS_TOKEN_TTL_SECONDS=86400
ONLYOFFICE_DOCUMENT_SERVER_URL=
ONLYOFFICE_JWT_SECRET=
ARCHITOKEN_OFFICE_EDIT_MAX_BYTES=

# 原生工程工作台会话目录与地址(不用原生工作台可留空)
ARCHITOKEN_ENGINEERING_NATIVE_SESSION_DIR=
ARCHITOKEN_ENGINEERING_NATIVE_WORKBENCH_PUBLIC_URL=
ARCHITOKEN_ENGINEERING_NATIVE_WORKBENCH_API_URL=

# 3DM / SKP 转 IFC 的本地转换命令(不用格式转换可留空)
PRENGINE_3DM_TO_IFC_COMMAND=
PRENGINE_SKP_TO_IFC_COMMAND=
PRENGINE_SKP_CONVERTER_COMMAND=
# SKETCHUP_ADAPTER_URL=
